{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "opencode/minimax-m2.7",
  "lsp": true,
  "formatter": true,
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "allow",
    "read": "allow",
    "webfetch": "ask",
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git log *": "allow",
      "git push": "allow",
      "gh pr create *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr checks *": "allow",
      "{{PM}} *": "allow",
      "{{PM}} test*": "allow",
      "{{PM}} run *": "allow",
      "rm -rf *": "deny",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "gh pr merge *": "ask",
      "* | sh": "deny",
      "* | bash": "deny",
      "curl * | *": "deny"
    }
  }
}
