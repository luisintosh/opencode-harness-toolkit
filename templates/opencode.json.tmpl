{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "opencode/minimax-m2.7",
  "lsp": true,
  "formatter": true,
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "rm -fr *": "deny",
      "rm -r *": "ask",
      "git clean *": "ask",
      "git reset --hard*": "deny",
      "git checkout -- *": "ask",
      "git restore *": "ask",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "gh pr merge *": "ask",
      "sudo *": "ask",
      "chmod -R *": "ask",
      "chown -R *": "ask",
      "* | sh": "deny",
      "* | bash": "deny",
      "curl * | *": "deny",
      "wget * | *": "deny"
    }
  }
}
